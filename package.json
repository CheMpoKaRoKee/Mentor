{
  "name": "learning-mentor",
  "version": "1.0.0",
  "description": "Desktop learning mentor for fullstack development",
  "author": "Learning Mentor",
  "main": "src/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
